# Provider routing
LLM_PROVIDER=deepseek
MODEL=deepseek-chat
FAST_MODEL=deepseek-chat
STANDARD_MODEL=deepseek-chat
REASONING_MODEL=deepseek-chat
LLM_BACKUP_MODELS=qwen-plus,ep-your-volcengine-endpoint-id
LLM_TIMEOUT_SECONDS=30
LLM_MAX_CANDIDATE_ATTEMPTS=2
LLM_MODEL_FAILURE_COOLDOWN_SECONDS=90
ORCHESTRATOR_TASK_TIMEOUT_SECONDS=90
USE_LANGGRAPH=false
REFLECTION_ENABLED=false
REFLECTION_MAX_ROUNDS=1
REFLECTION_MIN_CONFIDENCE=0.6
REFLECTION_COMPLEX_THRESHOLD=4
LLM_HEALTH_CACHE_ENABLED=true
LLM_HEALTH_CACHE_PATH=data/observability/llm_health.json
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=evoagent

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Volcengine Ark / 火山方舟 endpoint id, e.g. ep-xxxxxxxx
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Optional providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local runtime paths
EVO_DB_PATH=data/evoagent.db
EVO_SEMANTIC_PATH=data/semantic_store
EVO_SKILL_STORE_PATH=data/skills_store
EVO_WORKSPACE_STORE_PATH=data/workspaces

# Safety defaults
EVO_ALLOW_PRIVATE_NETWORK_FETCH=false
SKILL_RUNTIME_TIMEOUT_SECONDS=10
SANDBOX_BACKEND=auto
SKILL_ALLOWED_PERMISSIONS=sandbox,memory
SKILL_MIN_SUCCESSES=3
